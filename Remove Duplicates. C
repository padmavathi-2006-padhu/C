#include <stdio.h>

int main() {
    int n, i, j, arr[100];

    printf("Enter number of elements: ");
    scanf("%d", &n);

    printf("Enter elements: ");
    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    printf("Array after removing duplicates: ");

    for(i = 0; i < n; i++) {
        int isDuplicate = 0;

        for(j = 0; j < i; j++) {
            if(arr[i] == arr[j]) {
                isDuplicate = 1;
                break;
            }
        }

        if(!isDuplicate) {
            printf("%d ", arr[i]);
        }
    }

    return 0;
}
