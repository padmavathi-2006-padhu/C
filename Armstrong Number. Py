#include <stdio.h>
#include <math.h>

int main() {
    int n, temp, remainder, digits = 0;
    int original, total = 0;

    printf("Enter a number: ");
    scanf("%d", &n);

    original = n;
    temp = n;

    // Count number of digits
    while(temp != 0) {
        digits++;
        temp /= 10;
    }

    temp = n;

    // Calculate sum of powers
    while(temp != 0) {
        remainder = temp % 10;
        total += pow(remainder, digits);
        temp /= 10;
    }

    if(total == original)
        printf("Armstrong");
    else
        printf("Not Armstrong");

    return 0;
}
