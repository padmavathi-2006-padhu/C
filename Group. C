#include <stdio.h>
#include <sqlite3.h>

// Callback function
int callback(void *data, int argc, char **argv, char **colName) {
    printf("Dept: %s  Avg Marks: %s\n", argv[0], argv[1]);
    return 0;
}

int main() {
    sqlite3 *db;
    char *errMsg = 0;

    // Open database
    sqlite3_open("student.db", &db);

    // Execute GROUP BY query
    char *sql = "SELECT dept, AVG(marks) FROM Student GROUP BY dept;";
    
    printf("Department Wise Average:\n");
    sqlite3_exec(db, sql, callback, 0, &errMsg);

    // Close database
    sqlite3_close(db);

    return 0;
}
