#include <stdio.h>

int main() {
    float a, b;
    char op;

    printf("Enter two numbers: ");
    scanf("%f %f", &a, &b);

    printf("Enter operator (+, -, *, /): ");
    scanf(" %c", &op);

    if(op == '+') {
        printf("Result = %.2f", a + b);
    }
    else if(op == '-') {
        printf("Result = %.2f", a - b);
    }
    else if(op == '*') {
        printf("Result = %.2f", a * b);
    }
    else if(op == '/') {
        if(b != 0)
            printf("Result = %.2f", a / b);
        else
            printf("Error: Division by zero");
    }
    else {
        printf("Invalid Operator");
    }

    return 0;
}
