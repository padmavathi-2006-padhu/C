#include <stdio.h>

int main() {
    int n, i, num, even = 0, odd = 0;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    for(i = 1; i <= n; i++) {
        printf("Enter number: ");
        scanf("%d", &num);

        if(num % 2 == 0)
            even++;
        else
            odd++;
    }

    printf("Even: %d\n", even);
    printf("Odd: %d\n", odd);

    return 0;
}
